modules = ["nodejs-24"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[userenv]

[userenv.shared]
APP_URL = "https://65f34dac-eef3-4ade-8418-630f61a8056f-00-1zlrh1bqo1253.pike.replit.dev"
CRON_SCHEDULE = "0 */6 * * *"
FRONTEND_URL = "https://65f34dac-eef3-4ade-8418-630f61a8056f-00-1zlrh1bqo1253.pike.replit.dev"
GHOST_JOB_MIN_SCORE = "40"
JWT_EXPIRES_IN = "15m"
JWT_REFRESH_EXPIRES_IN = "7d"
LOG_LEVEL = "info"
MONGODB_URI = "mongodb://127.0.0.1:27017/autoapply"
NODE_ENV = "development"
PORT = "3000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MongoDB"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "MongoDB"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mongod --dbpath /home/runner/workspace/.data/mongodb --bind_ip 127.0.0.1 --port 27017 --logpath /home/runner/workspace/.data/mongodb-log/mongod.log --logappend"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx ng serve"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80
