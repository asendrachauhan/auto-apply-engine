# ─── COPY THIS TO .env AND FILL IN YOUR VALUES ────────────────────────────────
# NEVER commit .env to Git — it is in .gitignore

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

# ─── MongoDB Atlas (free at mongodb.com/atlas) ─────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/autoapply?retryWrites=true&w=majority

# ─── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional — cron expression for the automatic application run. Defaults to every 6 hours.
CRON_SCHEDULE=0 */6 * * *

# ─── AI Model — swap providers/models entirely from here, no code changes ──────
# Free tier at console.groq.com. GROQ_MODEL accepts any model in Groq's catalog
# (e.g. llama3-8b-8192, llama-3.3-70b-versatile, mixtral-8x7b-32768).
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192
# Optional — override to point at any other OpenAI-compatible endpoint/provider.
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional — generation tuning (defaults shown)
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.3
GROQ_RETRIES=2
# Optional — cosmetic label only, shown via GET /api/config/ai
AI_PROVIDER_LABEL=Groq

# ─── Cloudinary — free at cloudinary.com ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Adzuna — free at developer.adzuna.com ─────────────────────────────────────
ADZUNA_APP_ID=your_app_id
ADZUNA_API_KEY=your_api_key
ADZUNA_COUNTRY=in

# ─── Google Jobs via SerpAPI — free tier at serpapi.com (optional source) ──────
# SERPAPI_KEY=your_serpapi_key

# ─── Resend — free 3,000 emails/month at resend.com ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Twilio WhatsApp Sandbox — free at twilio.com ──────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Stripe — Price IDs must be created in your Stripe Dashboard first ─────────
# (Stripe requires pre-created Price objects; the amounts below are what your
# frontend DISPLAYS via /api/config/plans — make sure they match the actual
# price on each Stripe Price object.)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE=price_xxxxxxxxxxxxxxxxxxxx

# ─── Plan Pricing, Limits & Feature Copy ────────────────────────────────────────
# Everything below is optional — sensible defaults are built in (shown as
# comments). Uncomment and edit to change pricing, daily limits, which job
# sources each plan includes, real-time polling speed, trial length, or the
# marketing bullet points shown on /plans, all without touching any code.
# Served publicly (no secrets) via GET /api/config/plans.

PLAN_CURRENCY=INR
PLAN_CURRENCY_SYMBOL=₹

# PLAN_FREE_PRICE=0
# PLAN_FREE_DAILY_LIMIT=3
# PLAN_FREE_SOURCES=remotive,himalayas
# PLAN_FREE_FEATURES=["3 applications/day","Remotive + Himalayas","Basic AI resume parsing","Email notifications"]
# PLAN_FREE_CTA=Get Started Free

# PLAN_STARTER_NAME=Starter
# PLAN_STARTER_PRICE=299
# PLAN_STARTER_DAILY_LIMIT=15
# PLAN_STARTER_SOURCES=remotive,himalayas,adzuna
# PLAN_STARTER_REALTIME=false
# PLAN_STARTER_TRIAL_DAYS=7
# PLAN_STARTER_FEATURES=["15 applications/day","Remotive + Himalayas + Adzuna","AI resume tailoring per job","Email + WhatsApp alerts","7-day free trial"]
# PLAN_STARTER_CTA=Start Free Trial

# PLAN_PRO_NAME=Pro
# PLAN_PRO_PRICE=699
# PLAN_PRO_DAILY_LIMIT=50
# PLAN_PRO_SOURCES=remotive,himalayas,adzuna,arbeitnow
# PLAN_PRO_REALTIME=true
# PLAN_PRO_REALTIME_INTERVAL=120
# PLAN_PRO_TRIAL_DAYS=7
# PLAN_PRO_POPULAR=true
# PLAN_PRO_FEATURES=["50 applications/day","All legal job boards incl. Arbeitnow","Real-time job detection (2 min)","AI resume tailoring per job","Full notifications","7-day free trial"]
# PLAN_PRO_CTA=Go Pro

# PLAN_ELITE_NAME=Elite
# PLAN_ELITE_PRICE=1499
# PLAN_ELITE_DAILY_LIMIT=200
# PLAN_ELITE_SOURCES=remotive,himalayas,adzuna,arbeitnow
# PLAN_ELITE_REALTIME=true
# PLAN_ELITE_REALTIME_INTERVAL=60
# PLAN_ELITE_TRIAL_DAYS=7
# PLAN_ELITE_FEATURES=["200 applications/day","Real-time detection (1 min)","Priority apply queue","Advanced analytics","Priority support","7-day free trial"]
# PLAN_ELITE_CTA=Go Elite

# ─── Ghost Job Detection ─────────────────────────────────────────────────────
# Default minimum legitimacy score (0-100) for a job to be shown/applied to.
# Individual users can override this from their own Preferences page —
# this env var is only the fallback when they haven't set one.
GHOST_JOB_MIN_SCORE=40

# ─── App ────────────────────────────────────────────────────────────────────────
APP_URL=https://your-frontend-domain.com
LOG_LEVEL=info
